# Database — Railway will auto-inject DATABASE_URL via service reference.
# For local dev, fill in your own Postgres URL.
DATABASE_URL=

# Telegram Bot (created via @BotFather, then added to your sales group as admin)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Support bot (separate @BotFather bot, e.g. @birliy_support_bot).
# Collects name + phone + free-text question -> lead (source=support) in admin + group card.
# Register webhook after deploy: pnpm set-support-webhook
TELEGRAM_SUPPORT_BOT_TOKEN=
# Support webhook secret — random 32+ char hex (openssl rand -hex 32). Separate from the lead bot's.
TELEGRAM_SUPPORT_WEBHOOK_SECRET=

# Admin (HTTP Basic Auth for /admin/* routes)
ADMIN_USER=
ADMIN_PASSWORD=

# Public site URL (used in Telegram message link)
NEXT_PUBLIC_SITE_URL=https://ipak-savdo-landing-production.up.railway.app

# Webhook secret — set via setWebhook call. Random 32+ char hex string.
# Generate: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=

# ─── Google Analytics ───
# Client-side GA4 page-view tracking (public measurement id, ships in the browser bundle).
# Already live in production as G-010JJYEXTQ. Without it, components/Analytics.tsx renders nothing.
NEXT_PUBLIC_GA_ID=G-010JJYEXTQ

# Admin GA dashboard (/admin/analytics) — pulls users/sessions/sources/pages via the GA4 Data API.
# Both are needed for the dashboard to show numbers; the public tracking above works without them.
# GA_PROPERTY_ID: the NUMERIC GA4 property id (Analytics > Admin > Property Settings),
#   NOT the G-XXXX measurement id. Example: 123456789
GA_PROPERTY_ID=
# GA_CREDENTIALS_JSON: the FULL service-account JSON key (one value). Secret — set it only in the
#   Railway dashboard, never commit it. The service account needs Viewer access on the GA4 property.
#   See D:\Fable-birliy-rec\GA-SETUP.md for the step-by-step.
GA_CREDENTIALS_JSON=

# ─── Yandex Metrika ───
# Client-side Yandex Metrika tracking (public NUMERIC counter id, ships in the browser bundle).
# Live counter for birliy.uz is 109921799, also hardcoded as the default in
# components/YandexMetrika.tsx, so tracking works without this var. Set it only to override.
NEXT_PUBLIC_YANDEX_METRIKA_ID=109921799

# ─── Search-engine ownership verification (server-rendered meta tags) ───
# Token from Yandex Webmaster (https://webmaster.yandex.ru) "meta tag" verification method.
# Live token is 9edd4bcada30a5c7, also hardcoded as the default in app/layout.tsx.
YANDEX_VERIFICATION=9edd4bcada30a5c7
# Token from Google Search Console (https://search.google.com/search-console) "HTML tag" method
# (the content value of the google-site-verification meta tag).
# Live token hardcoded as the default in app/layout.tsx.
GOOGLE_SITE_VERIFICATION=hsbWtLtcG8YCe2unHP93eBGdi8x0tc5Rdq2DXrMPytk

# ─── Phase 2 growth dashboard (admin /admin/analytics) ───
# All of the below are SERVER-ONLY and read on the server; they are never exposed
# to the browser. Each admin section shows a graceful empty state when its env is
# missing. Set the real values only in the Railway dashboard, never commit them.

# Yandex Metrika Reporting/Stat API (admin "Yandex Metrika" section).
# COUNTER_ID is the same numeric counter as the public tracker (109921799).
# OAUTH_TOKEN is a long-lived Yandex OAuth token with read access to the counter
# (issue once at https://oauth.yandex.com — Metrika "get-stat" scope).
YANDEX_METRIKA_COUNTER_ID=109921799
YANDEX_METRIKA_OAUTH_TOKEN=

# Google Search Console Search Analytics API (admin "Search Growth" section).
# SITE_URL: use the domain-property form "sc-domain:birliy.uz" (or a URL-prefix
#   like "https://birliy.uz/"). If unset the code falls back to GSC_SITE_URL then
#   "https://birliy.uz/".
# CREDENTIALS_JSON: the service-account JSON key. If unset the code falls back to
#   the existing GA_CREDENTIALS_JSON (same service account powers GA4 + GSC), so
#   you usually do NOT need to set this separately.
GOOGLE_SEARCH_CONSOLE_SITE_URL=sc-domain:birliy.uz
GOOGLE_SEARCH_CONSOLE_CREDENTIALS_JSON=

# SerpApi (admin "Keyword Rank Tracker" section). Server-side only, manual refresh
# only (never called during build or page render). Each tracked keyword costs 1
# SerpApi credit per refresh; results are snapshotted in the keyword_ranks table.
SERPAPI_API_KEY=

# ─── AI Growth OS internal API ───
# Shared bearer token for trusted callers such as cmo-cloud, n8n, or Paperclip.
# Required for /api/content-objects. Generate a long random value and store it in Railway env.
AIOS_INTERNAL_TOKEN=
