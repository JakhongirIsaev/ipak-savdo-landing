      "effective_status": "needs_confirmation"
    },
    "notes": [
      "Existing landing-page marketing copy is not treated as independent factual proof.",
      "Prompt text, old specifications, mockups, and demo data are never runtime-public evidence.",
      "Temporary owner decisions are conservative until Jack confirms otherwise."
    ]
  },
  "source_classification_rules": [
    {
      "match": "demo dashboard, sample receipt, mock metric, fixture number",
      "source_classification": "demo_placeholder",
      "effective_status": "prohibited"
    },
    {
      "match": "old specification, prompt, planning document, unused roadmap copy",
      "source_classification": "specification_only",
      "effective_status": "needs_confirmation"
    },
    {
      "match": "current landing page, blog post, i18n marketing copy",
      "source_classification": "marketing_copy_only",
